meta {
  name: Refresh
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/v1/auth/refresh
  body: json
  auth: none
}

body:json {
  {
    "refresh_token": "{{refreshToken}}"
  }
}

script:post-response {
  if (res.getStatus() < 300 && res.getBody()?.data?.token) {
    bru.setEnvVar("accessToken", res.getBody().data.token.access_token);
    bru.setEnvVar("refreshToken", res.getBody().data.token.refresh_token);
  }
}
