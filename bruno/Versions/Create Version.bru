meta {
  name: Create Version
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/projects/{{projectId}}/versions
  body: json
  auth: inherit
}

body:json {
  {
    "object_snapshot": {},
    "created_by": null
  }
}

script:post-response {
  if (res.getStatus() < 300 && res.getBody()?.data?.id) {
    bru.setEnvVar("versionId", res.getBody().data.id);
  }
}
