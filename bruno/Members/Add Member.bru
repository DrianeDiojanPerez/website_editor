meta {
  name: Add Member
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/projects/{{projectId}}/members
  body: json
  auth: inherit
}

body:json {
  {
    "user_id": 2,
    "role": "editor"
  }
}

script:post-response {
  if (res.getStatus() < 300 && res.getBody()?.data?.id) {
    bru.setEnvVar("memberId", res.getBody().data.id);
  }
}
